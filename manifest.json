{
  "manifest_version": 3,
  "name": "Prompt Collector for Feishu",
  "description": "Collect image-generation prompts from web pages into an existing Feishu Base table.",
  "version": "0.4.13",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "clipboardRead", "contextMenus", "scripting", "sidePanel", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Prompt Collector for Feishu",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "side_panel": {
    "default_path": "popup.html?mode=side"
  },
  "options_page": "options.html"
}
